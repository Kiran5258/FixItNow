# Database Configuration
DB_URL=jdbc:mysql://localhost:3306/FixItNow?createDatabaseIfNotExist=true
DB_USERNAME=root
DB_PASSWORD=your_password_here

# Server Configuration
SERVER_PORT=8080

# JWT Configuration (MUST be at least 32 characters long)
JWT_SECRET=your_jwt_secret_key_min_32_characters_long_change_this
JWT_EXPIRATION=3600000

# Admin Account Configuration (Change these in production!)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=ChangeThisStrongPassword123!

# CORS Configuration (comma-separated for multiple origins)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# File Upload Configuration
MAX_FILE_SIZE=10MB
MAX_REQUEST_SIZE=10MB
